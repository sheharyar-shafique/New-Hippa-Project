# ============================================================================
# NoteMD backend — environment variables
# Copy this file to `.env` (local dev) or set in Vercel project settings (prod).
# NEVER commit `.env` — it's already in .gitignore.
# ============================================================================

# ─── Supabase Postgres ─────────────────────────────────────────────────────
# In your Supabase project: Settings → Database → Connection string → ORMs
# (or click the "Connect" button at the top of the dashboard).
#
# You need BOTH URLs:
#
#   DATABASE_URL — Transaction pooler (port 6543). Used for runtime queries
#                  in serverless functions. Includes `?pgbouncer=true`.
#   DIRECT_URL   — Direct connection (port 5432). Used for Prisma migrations
#                  ONLY. Bypasses the pooler.
#
# Copy them verbatim from Supabase and paste below. Replace [YOUR-PASSWORD]
# with the database password you set when you created the project.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Auth (JWT) ────────────────────────────────────────────────────────────
# Used to sign auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Or paste any random 48+ character string.
JWT_SECRET="replace-me-with-a-long-random-string-of-at-least-48-chars"
JWT_EXPIRES_IN="7d"

# ─── Anthropic (Claude) — SOAP + lab interpretation ───────────────────────
# Get a key at: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL_TEXT="claude-sonnet-4-5"
ANTHROPIC_MODEL_VISION="claude-sonnet-4-5"

# ─── OpenAI (Whisper) — audio transcription ───────────────────────────────
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
OPENAI_WHISPER_MODEL="whisper-1"

# ─── Vercel Blob — audio + lab image storage ──────────────────────────────
# Vercel dashboard → Storage → Create Blob Store → copy the Read-Write token.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── CORS ──────────────────────────────────────────────────────────────────
# The frontend origin allowed to call this API. Comma-separated for multiple.
# Local dev:   http://localhost:5173
# Production:  https://notemd.vercel.app  (replace with your frontend URL)
ALLOWED_ORIGIN="http://localhost:5173"
