# ============================================================================
# NoteMD frontend — environment variables
# Copy this file to `.env` (local) or set in Vercel project settings (prod).
# ============================================================================

# Base URL the frontend uses to call the backend API.
#
# Local dev (running `vercel dev` in ../backend):
#   VITE_API_BASE="http://localhost:3000/api"
#
# Production (after deploying ../backend as its own Vercel project):
#   VITE_API_BASE="https://notemd-api.vercel.app/api"
VITE_API_BASE="http://localhost:3000/api"

# Default UI language ("es" | "en"). Spanish-first per product positioning.
VITE_DEFAULT_LANG="es"
