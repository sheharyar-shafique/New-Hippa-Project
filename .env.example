# ============================================================================
# NoteMD environment variables
# Copy this file to `.env` and fill in real values.
# DO NOT commit `.env` to git (it's already in .gitignore).
# ============================================================================

# --- Database ---------------------------------------------------------------
# Postgres connection string. Easiest free option: https://neon.tech (signup
# ~30 seconds, copy the connection string from the dashboard).
# Alternatives: Vercel Postgres, Supabase, Railway, AWS RDS.
DATABASE_URL="postgresql://user:password@host:5432/notemd?sslmode=require"

# --- Auth -------------------------------------------------------------------
# Used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Or just paste any random 48+ character string.
JWT_SECRET="replace-me-with-a-long-random-string-of-at-least-48-chars"

# JWT expiry — how long an auth token stays valid (default 7 days).
JWT_EXPIRES_IN="7d"

# --- Anthropic (Claude) -----------------------------------------------------
# Powers SOAP note generation and lab image interpretation.
# Get a key at: https://console.anthropic.com → API keys
ANTHROPIC_API_KEY="sk-ant-..."

# Models to use. Defaults are sensible for medical use:
ANTHROPIC_MODEL_TEXT="claude-sonnet-4-5"
ANTHROPIC_MODEL_VISION="claude-sonnet-4-5"

# --- OpenAI (Whisper) -------------------------------------------------------
# Powers audio transcription for the consultation recorder.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Whisper model. Default is fine for clinical audio.
OPENAI_WHISPER_MODEL="whisper-1"

# --- File storage (Vercel Blob) --------------------------------------------
# Stores audio recordings and lab images.
# Set up: Vercel dashboard → Storage → Create Blob Store → copy the token.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Frontend ---------------------------------------------------------------
# Base URL the frontend uses to call the API. For local dev with `vercel dev`,
# this is "/api". For production on Vercel, also "/api".
VITE_API_BASE="/api"

# Default UI language ("es" | "en"). Spanish-first per product positioning.
VITE_DEFAULT_LANG="es"
